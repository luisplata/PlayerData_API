{
    "name": "playerapi",
    "version": "1.0.0",
    "description": "A simple RESTful API for managing players using Node.js and Express.",
    "main": "index.js",
    "scripts": {
        "start": "node index.js",
        "dev": "nodemon index.js",
        "migrate": "knex migrate:latest",
        "clean": "knex migrate:rollback --all",
        "seed": "knex seed:run",
        "migrate:rollback": "knex migrate:rollback",
        "clean:migrate": "npm run clean && npm run migrate",
        "clean:migrate:seed": "npm run clean && npm run migrate && npm run seed",
        "heroes:admin:create": "node scripts/heroes/manageHeroes.js --action=create --input=scripts/heroes/data/create.hero-example.json",
        "heroes:admin:list": "node scripts/heroes/manageHeroes.js --action=list",
        "heroes:admin:get": "node scripts/heroes/manageHeroes.js --action=get --input=scripts/heroes/data/get.hero-example.json",
        "heroes:admin:update": "node scripts/heroes/manageHeroes.js --action=update --input=scripts/heroes/data/update.hero-example.json",
        "heroes:admin:delete": "node scripts/heroes/manageHeroes.js --action=delete --input=scripts/heroes/data/delete.hero-example.json",
        "dialogs:admin:create": "node scripts/dialogs/manageDialogs.js --action=create --input=scripts/dialogs/data/create.dialog-example.json",
        "dialogs:admin:list": "node scripts/dialogs/manageDialogs.js --action=list --input=scripts/dialogs/data/list.dialog-example.json",
        "dialogs:admin:get": "node scripts/dialogs/manageDialogs.js --action=get --input=scripts/dialogs/data/get.dialog-example.json",
        "dialogs:admin:delete": "node scripts/dialogs/manageDialogs.js --action=delete --input=scripts/dialogs/data/delete.dialog-example.json",
        "test": "npm run test:unit",
        "test:unit": "mocha \"test/{controllers,entities,middlewares,migrations,repositories,useCases}/**/*.test.js\"",
        "test:integration": "mocha \"test/*.test.js\"",
        "test:all": "npm run test:unit && npm run test:integration",
        "test:watch": "mocha --watch",
        "test:coverage": "nyc mocha",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.0.3",
        "express": "^4.18.2",
        "express-jwt": "^8.4.1",
        "express-rate-limit": "^5.5.1",
        "helmet": "^4.6.0",
        "jsonwebtoken": "^9.0.2",
        "knex": "^1.0.7",
        "mysql2": "^3.11.4",
        "pg": "^8.7.1",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.0",
        "winston": "^3.17.0"
    },
    "devDependencies": {
        "chai": "^4.3.7",
        "chai-http": "^4.3.0",
        "eslint": "^8.50.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-prettier": "^5.0.0",
        "mocha": "^10.2.0",
        "nodemon": "^3.0.1",
        "nyc": "^15.1.0",
        "prettier": "^3.0.0"
    }
}
